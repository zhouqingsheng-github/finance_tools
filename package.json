{
  "name": "qingflow",
  "version": "1.0.0",
  "private": true,
  "description": "QingFlow 清流 - 多商家数据采集与自动化对账工作台",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vue\" \"npm run dev:electron\"",
    "dev:vue": "cd src && npx vite",
    "dev:electron": "npx tsc -p electron/tsconfig.json && node scripts/wait-vite.js && electron .",
    "dev:electron:fast": "node scripts/wait-vite.js && electron .",
    "build:icons": "node scripts/make-windows-icon.js",
    "build:electron": "npx tsc -p electron/tsconfig.json",
    "build:vue": "cd src && npx vite build",
    "build:app": "npm run build:vue && npm run build:electron",
    "build": "npm run build:app && electron-builder --win --publish never",
    "build:mac": "npm run build:app && electron-builder --mac --x64 --arm64 --publish never",
    "build:mac:x64": "npm run build:app && electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "npm run build:app && electron-builder --mac --arm64 --publish never",
    "build:mac:universal": "npm run build:app && electron-builder --mac --universal --publish never",
    "preview": "cd src && npx vite preview"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.zhouqingsheng.qingflow",
    "productName": "QingFlow",
    "icon": "resources/qingflow.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "src/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "python", "to": "python" },
      { "from": "shared", "to": "shared" },
      { "from": "src/assets/qingflow-logo.png", "to": "assets/qingflow-logo.png" },
      { "from": "resources/python-runtime", "to": "python-runtime" },
      { "from": "resources/ms-playwright", "to": "ms-playwright" }
    ],
    "win": {
      "icon": "resources/qingflow.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "resources/qingflow.ico",
      "uninstallerIcon": "resources/qingflow.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    }
  }
}
